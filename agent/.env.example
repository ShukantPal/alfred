# agent/ layer environment

# --- Talon delegate provider ---
# Default provider is OpenAI. Set LLM_PROVIDER=wandb to use W&B Inference.
LLM_PROVIDER=openai
OPENAI_API_KEY=
WANDB_API_KEY=
WEAVE_PROJECT=meeting-agent

# Required local Talon auth secret. Alfred mints a fresh JWT for each Talon RPC.
TALON_JWT_SECRET=

# Optional Talon overrides.
# TALON_NAMESPACE=alfred
# TALON_COMPANY_AGENT=company-memory
# TALON_PROVIDER_NAME=openai
# TALON_PROVIDER_BASE_URL=
# TALON_MODEL=gpt-4.1-mini
# TALON_DATA_DIR=.tools/talon/data
# TALON_WORKSPACE_DIR=.tools/talon/workspace
# TALON_JWT_TTL_SECONDS=86400
# TALON_DELEGATE_TIMEOUT_MS=20000

# --- Company-memory MCP ---
# Unset TALON_COMPANY_MCP_URL to use agent/src/memory-mcp.ts over stdio.
# TALON_COMPANY_MCP_URL=
# REDIS_MCP_URL=
# TALON_COMPANY_MCP_NAME=company-memory
# TALON_MEMORY_MCP_COMMAND=
# TALON_MEMORY_MCP_ARGS_JSON=
# TALON_COMPANY_MCP_HEADERS_JSON=

# --- Google Workspace MCP ---
# The Google Workspace MCP is only attached if it is authable and the command exists.
# Defaults to: uvx workspace-mcp --single-user --tools gmail drive docs calendar --read-only
TALON_WORKSPACE_MCP_ENABLED=true
# TALON_WORKSPACE_MCP_NAME=google-workspace
# TALON_WORKSPACE_MCP_COMMAND=uvx
# TALON_WORKSPACE_MCP_ARGS_JSON=["workspace-mcp","--single-user","--tools","gmail","drive","docs","calendar","--read-only"]

# Provide env credentials or a client secret file. If GOOGLE_CLIENT_SECRET_PATH is unset,
# agent also checks legacy GOOGLE_CLIENT_SECRETS and ./client_secret.json at the repo root.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# FASTMCP_SERVER_AUTH_GOOGLE_JWT_SIGNING_KEY=
# GOOGLE_CLIENT_SECRET_PATH=
# GOOGLE_CLIENT_SECRETS=
# OAUTHLIB_INSECURE_TRANSPORT=1

# --- Web search MCP ---
# DuckDuckGo search MCP is no-auth and read-only. It is attached if uvx exists.
TALON_SEARCH_MCP_ENABLED=true
# TALON_SEARCH_MCP_NAME=duckduckgo-search
# TALON_SEARCH_MCP_COMMAND=uvx
# TALON_SEARCH_MCP_ARGS_JSON=["duckduckgo-mcp-server"]
