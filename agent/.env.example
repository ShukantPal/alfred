# agent/ layer environment

# --- LLM provider (OpenAI-compatible) ---
# Choose the model backend. Default: wandb (W&B Inference). Set "openai" to use OpenAI directly.
LLM_PROVIDER=wandb

# W&B Inference + Weave tracing share ONE key. Get it at https://wandb.ai/settings
WANDB_API_KEY=
# Optional: usage tracking on W&B Inference, format: <team>/<project>
WANDB_INFERENCE_PROJECT=

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Optional overrides (defaults are provider-specific; see src/llm.ts)
#   wandb  -> FAST=Qwen/Qwen3-30B-A3B-Instruct-2507  SMART=Qwen/Qwen3-235B-A22B-Instruct-2507
#   openai -> FAST=gpt-4o-mini                        SMART=gpt-4o
# FAST_MODEL=
# SMART_MODEL=
# LLM_BASE_URL=

# --- Memory ---
REDIS_URL=redis://127.0.0.1:6379

# --- Weave (observability) ---
WEAVE_PROJECT=meeting-agent

# --- Server ---
AGENT_PORT=8787
