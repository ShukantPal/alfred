{
  "name": "@alfred/agent",
  "version": "0.1.0",
  "private": true,
  "description": "Agent layer: configures Alfred's Talon-backed company-memory delegate.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "demo": "bun src/demo-client.ts",
    "test-agent": "bun src/test-agent.ts",
    "memory-mcp": "bun src/memory-mcp.ts",
    "slack-mcp": "bun src/slack-mcp.ts",
    "github-mcp": "bun src/github-mcp.ts"
  },
  "dependencies": {
    "@connectrpc/connect": "^1.7.0",
    "@connectrpc/connect-node": "^1.7.0",
    "@impalasys/talon-client": "^0.1.17",
    "@impalasys/talon-server": "^0.1.17",
    "dotenv": "^17.4.2",
    "weave": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
